@model TecnologiaViewModel
@{
    ViewData["Title"] = Model.Nome;
}

<div class="sc-page-actions mb-4">
    <a href="/Tecnologias" class="btn btn-nasa-outline btn-sm">← Voltar ao catálogo</a>
    @if (User.IsInRole("Administrador"))
    {
        <a href="/Tecnologias/Editar/@Model.Id" class="btn btn-nasa btn-sm">Editar</a>
        <a href="/Tecnologias/Excluir/@Model.Id" class="btn btn-nasa-red btn-sm">Excluir</a>
    }
</div>

<div class="sc-dossier-hero sc-parallax reveal" data-parallax="0.22">
    <div class="sc-feature-img sc-parallax-inner rounded-0" style="height: 360px;">
        <img src="@NasaUi.SpinoffImage(Model.Id, Model.CategoriaNome)" alt="@Model.Nome" />
        @if (Model.CategoriaNome != null)
        {
            <span class="sc-kicker">@Model.CategoriaNome</span>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8 reveal">
        <p class="sc-kicker mb-2">Dossiê de spinoff</p>
        <h1 class="display-6 fw-bold mb-4">@Model.Nome</h1>

        <div class="sc-form-panel mb-4">
            <div class="sc-lineage-item mb-4">
                <div class="sc-lineage-label">Origem espacial</div>
                <p class="mb-0 fs-6" style="line-height:1.65">@Model.Descricao</p>
            </div>
            @if (!string.IsNullOrEmpty(Model.AplicacaoTerra))
            {
                <div class="sc-lineage-item">
                    <div class="sc-lineage-label">Aplicação na Terra</div>
                    <p class="mb-0 fw-semibold fs-5">@Model.AplicacaoTerra</p>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4 reveal">
        <div class="sc-dossier-meta">
            <div class="sc-form-panel mb-3">
                <dl class="sc-dossier-meta mb-0">
                    <dt>Ano de origem</dt>
                    <dd class="fw-bold fs-3 mb-0" style="color:var(--cyan)">@(Model.AnoOrigem?.ToString() ?? "—")</dd>

                    @if (Model.MissaoNome != null)
                    {
                        <dt class="mt-3">Missão associada</dt>
                        <dd class="fw-semibold mb-0">@Model.MissaoNome</dd>
                    }

                    @if (Model.CategoriaNome != null)
                    {
                        <dt class="mt-3">Setor de impacto</dt>
                        <dd class="mb-0">
                            <span class="sc-cat-pill" style="background: @(Model.CategoriaCorHex)22; color: @(Model.CategoriaCorHex); border-color: @(Model.CategoriaCorHex)55">@Model.CategoriaNome</span>
                        </dd>
                    }

                    <dt class="mt-3">Registrado em</dt>
                    <dd class="text-muted mb-0">@Model.CriadoEm.ToString("dd/MM/yyyy 'às' HH:mm")</dd>
                </dl>
            </div>

            <div class="sc-aside-note">
                Referência: programa de
                <a href="https://www.nasa.gov/" target="_blank" rel="noopener">Technology Transfer</a>
                da NASA — soluções criadas para o espaço que revolucionam a vida na Terra.
            </div>
        </div>
    </div>
</div>
