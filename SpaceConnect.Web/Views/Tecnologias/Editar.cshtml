@model CriarTecnologiaViewModel
@{
    ViewData["Title"] = "Editar spinoff";
    var techId = ViewBag.TecnologiaId;
}

<div class="sc-section-head mb-4">
    <p class="sc-kicker mb-1">Administrador</p>
    <h2 class="mb-0">Editar spinoff</h2>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="sc-form-panel">
            <form asp-action="Editar" asp-route-id="@techId" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Descricao" class="form-label">Origem espacial</label>
                    <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="AplicacaoTerra" class="form-label">Aplicação na Terra</label>
                    <textarea asp-for="AplicacaoTerra" class="form-control" rows="2"></textarea>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="CategoriaId" class="form-label">Setor</label>
                        <select asp-for="CategoriaId" class="form-select">
                            <option value="">Selecione…</option>
                            @foreach (var cat in Model.Categorias)
                            {
                                <option value="@cat.Id">@cat.Nome</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="AnoOrigem" class="form-label">Ano</label>
                        <input asp-for="AnoOrigem" class="form-control" type="number" min="1900" max="2100" />
                    </div>
                </div>
                <div class="mb-4">
                    <label asp-for="MissaoId" class="form-label">Missão</label>
                    <select asp-for="MissaoId" class="form-select">
                        <option value="">Nenhuma</option>
                        @foreach (var m in Model.Missoes)
                        {
                            <option value="@m.Id">@m.Nome — @m.Agencia (@m.Ano)</option>
                        }
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-nasa">Salvar</button>
                    <a href="/Tecnologias/Detalhes/@techId" class="btn btn-nasa-outline">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
