<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SpaceConnect — arquivo de spinoffs espaciais e impacto na Terra." />
    <meta name="theme-color" content="#030712" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | " : "")SpaceConnect</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/spaceconnect.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="sc-body sc-page-enter">

<div class="sc-grain" aria-hidden="true"></div>

<header class="sc-header @(ViewData["EditorialHero"] as bool? == true ? "sc-header-editorial" : "sticky-top")">
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-lg-4">
            <a class="navbar-brand sc-brand" href="/">
                <span class="sc-logo-mark" aria-hidden="true"></span>
                <span class="sc-brand-text">
                    SpaceConnect
                    <small>Spinoff archive</small>
                </span>
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#scNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="scNav">
                    <ul class="navbar-nav me-auto ms-lg-3 gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" href="/">Painel</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tecnologias" ? "active" : "")" href="/Tecnologias">Spinoffs</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Missoes" ? "active" : "")" href="/Missoes">Missões</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categorias" ? "active" : "")" href="/Categorias">Setores</a>
                        </li>
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Tecnologias/Criar">Novo</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3 py-2 py-lg-0">
                        <div class="text-end d-none d-md-block">
                            <div class="text-white small fw-semibold">@User.Identity.Name</div>
                            <span class="sc-role-tag">@(User.FindFirst("Perfil")?.Value ?? "Pesquisador")</span>
                        </div>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-light">Sair</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </nav>
</header>

<main class="sc-main">
    @if (TempData["Sucesso"] != null || TempData["Erro"] != null)
    {
        <div class="sc-container sc-container-alerts">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert alert-success mb-4">@TempData["Sucesso"]</div>
            }
            @if (TempData["Erro"] != null)
            {
                <div class="alert alert-danger mb-4">@TempData["Erro"]</div>
            }
        </div>
    }

    @if (ViewData["EditorialHero"] as bool? == true)
    {
        @RenderBody()
    }
    else
    {
        <div class="sc-container sc-page">
            @RenderBody()
        </div>
    }
</main>

<footer class="sc-footer">
    <div class="container-fluid px-lg-4 d-flex flex-wrap justify-content-between gap-2 align-items-center">
        <div>
            <strong>SpaceConnect</strong> · FIAP GS 2025 · 3ESPR
        </div>
        <div class="small">Nova Economia Espacial</div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/spaceconnect.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
