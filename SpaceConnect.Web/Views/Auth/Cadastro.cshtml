@model CadastroViewModel
@{
    Layout = null;
    ViewData["Title"] = "Criar conta";
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#030712" />
    <title>Criar conta | SpaceConnect</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/spaceconnect.css" asp-append-version="true" />
</head>
<body class="sc-page-enter">
<div class="cosmos-bg" aria-hidden="true">
    <div class="cosmos-orb cosmos-orb-1"></div>
    <div class="cosmos-orb cosmos-orb-2"></div>
</div>
<div class="sc-auth-wrap">
    <div class="sc-auth-hero" style="@NasaUi.HeroStyle(NasaUi.AuthHeroImage)">
        <blockquote>
            Dados e inovação espacial abrem caminhos para uma economia que ainda está sendo inventada.
            <cite>FIAP Global Solution 2025 · 3ESPR</cite>
        </blockquote>
    </div>
    <div class="sc-auth-panel">
        <div class="d-flex align-items-center gap-2 mb-4">
            <span class="sc-logo-mark"></span>
            <div>
                <strong class="fs-5" style="color:var(--text)">SpaceConnect</strong>
                <div class="small text-muted">Spinoff archive</div>
            </div>
        </div>
        <h1 class="h3 fw-bold mb-1">Criar conta</h1>
        <p class="text-muted mb-4">Novos usuários entram como <strong>Pesquisador</strong>. Administradores são cadastrados pela equipe.</p>

        <form asp-action="Cadastro" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Perfil" value="Pesquisador" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" autocomplete="name" />
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" type="email" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Senha" class="form-label"></label>
                <input asp-for="Senha" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmaSenha" class="form-label"></label>
                <input asp-for="ConfirmaSenha" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="ConfirmaSenha" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-nasa w-100">Criar conta</button>
        </form>

        <p class="text-center text-muted small mt-4 mb-0">
            Já tem conta? <a href="/Auth/Login">Entrar</a>
        </p>
    </div>
</div>
<partial name="_ValidationScriptsPartial" />
<script src="~/js/spaceconnect.js" asp-append-version="true"></script>
</body>
</html>
